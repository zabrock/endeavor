{
  "name": "endeavor-retire",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/electronMain.js",
  "scripts": {
    "build": "tsc -p .",
    "test": "node run-tests.js",
    "ui:dev": "vite --config ./vite.config.ts",
    "ui:build": "vite build --config ./vite.config.ts",
    "electron:dev": "NODE_ENV=development electron .",
    "dev": "concurrently \"npm:ui:dev\" \"npm:electron:dev\"",
    "start": "npm run build && npm run ui:build && electron ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-plotly.js": "^2.5.1",
    "plotly.js-basic-dist": "^2.24.1"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^26.4.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.3"
  }
}

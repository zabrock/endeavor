{
  "name": "endeavor-devcontainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "npm_config_platform": "linux",
    "npm_config_arch": "x64"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
  },
  "forwardPorts": [],
  "postCreateCommand": "npm install",
  "remoteUser": "vscode"
}
